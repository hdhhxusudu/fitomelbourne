# Public site URL (optional; improves canonical URLs and sitemap in production)
# NEXT_PUBLIC_SITE_URL=https://peptides4u.com

# Cloudflare deploy auth (set in .env.local only — never commit)
# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
# CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Hosted checkout URL (used on /pay). Set ONE of these — Stripe name is checked first.
# NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://buy.stripe.com/test_xxxxxxxxxxxxx
# NEXT_PUBLIC_PAYMENT_LINK=https://your-domain.com/checkout-or-paypal-or-other
